<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Glowing background aura centered beneath emblem -->
    <path
        android:pathData="M54,54m-35,0a35,35 0,1 1,70 0a35,35 0,1 1,-70 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="35"
                android:type="radial">
                <item android:offset="0" android:color="#406366F1"/>
                <item android:offset="1" android:color="#00000000"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Outer futuristic tech hexagon/shield outline (Main emblem container) -->
    <path
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M 54,23 L 26,40 L 26,68 L 54,90 L 82,68 L 82,40 Z">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="26"
                android:startY="23"
                android:endX="82"
                android:endY="90"
                android:type="linear">
                <item android:offset="0" android:color="#6366F1"/>
                <item android:offset="0.5" android:color="#8B5CF6"/>
                <item android:offset="1" android:color="#10B981"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Inner dynamic progress delta caret / arrow pointing straight up -->
    <path
        android:strokeWidth="1.2"
        android:strokeColor="#FFFFFF"
        android:strokeLineJoin="round"
        android:pathData="M 54,44 L 37,71 L 46,71 L 54,58 L 62,71 L 71,71 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="37"
                android:startY="44"
                android:endX="71"
                android:endY="71"
                android:type="linear">
                <item android:offset="0" android:color="#10B981"/>
                <item android:offset="1" android:color="#0EA5E9"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Central AI coordinate node (Sparkle star) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 54,28 C 54,32 54,34 50,34 C 54,34 54,36 54,40 C 54,36 54,34 58,34 C 54,34 54,32 54,28 Z" />

    <!-- Auxiliary sparkle node (Top Right) -->
    <path
        android:fillColor="#22D3EE"
        android:pathData="M 74,32 C 74,35 74,36 71,36 C 74,36 74,37 74,40 C 74,37 74,36 77,36 C 74,36 74,35 74,32 Z" />

    <!-- Auxiliary sparkle node (Bottom Left) -->
    <path
        android:fillColor="#34D399"
        android:pathData="M 34,70 C 34,72 34,73 32,73 C 34,73 34,74 34,76 C 34,74 34,73 36,73 C 34,73 34,72 34,70 Z" />
</vector>
